{
  "name": "openclaw-gktrader",
  "version": "0.1.0",
  "private": true,
  "description": "Restricted GKTrader tool plugin for OpenClaw. Calls only the loopback FastAPI service.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "node --import tsx --test tests/*.test.ts",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "typebox": "^1.1.38"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.22.4",
    "typescript": "^5.8.0"
  },
  "engines": {
    "node": ">=20"
  }
}
